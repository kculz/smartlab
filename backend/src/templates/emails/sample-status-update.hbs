<html>
  <body style="font-family: Arial, sans-serif; color: #1f2937; line-height: 1.6;">
    <h2>Sample Status Update</h2>
    <p>Hi {{patientName}},</p>
    <p>Your sample <strong>{{sampleId}}</strong> has moved to <strong>{{stage}}</strong>.</p>
    <p><strong>Status:</strong> {{status}}</p>
    <p><strong>Tests:</strong> {{testNames}}</p>
    <p><a href="{{trackingUrl}}">Track your sample</a></p>
