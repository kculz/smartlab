<html>
  <body style="font-family: Arial, sans-serif; color: #1f2937; line-height: 1.6;">
    <h2>Invoice Created</h2>
    <p>Hi {{patientName}},</p>
    <p>Your invoice <strong>{{invoiceNumber}}</strong> is now available.</p>
    <p><strong>Total:</strong> {{totalAmount}} {{currency}}</p>
    <p><strong>Balance due:</strong> {{balanceDue}} {{currency}}</p>
    <p><strong>Line items:</strong> {{itemSummary}}</p>
    <p><a href="{{invoicesUrl}}">View invoice details</a></p>
    <p>Best regards,<br>{{appName}} Team</p>
  </body>
</html>
